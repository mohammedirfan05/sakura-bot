# ─────────────────────────────────────────────
#  🌸 Sakura Bot — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# ── Required ──────────────────────────────────
# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# Your Discord server (guild) ID
GUILD_ID=1521335974783881306

# ── Phase 2: AI Chat ─────────────────────────
# Groq API key — free tier, no credit card required
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
